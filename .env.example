# ── Copy this file to .env and adjust before running ─────────────────────────

# Whisper model to use.
# Options: tiny | base | small | medium | large | large-v2 | large-v3
# large-v3 gives best quality; use small/medium for faster dev/testing.
WHISPER_MODEL=large-v3

# Compute device: auto | cuda | cpu
# "auto" chooses cuda if a GPU is present, else cpu.
WHISPER_DEVICE=auto

# Compute type for faster-whisper: auto | float16 | int8 | float32
# "auto" picks float16 on GPU, int8 on CPU.
WHISPER_COMPUTE_TYPE=auto

# Beam size (5 is the Whisper default; lower = faster, higher = marginally better)
WHISPER_BEAM_SIZE=5

# Voice Activity Detection: automatically skip silent regions
WHISPER_VAD_FILTER=true

# Directory for temporary files (created automatically)
UPLOAD_DIR=tmp

# Maximum upload size in MB (2048 = 2 GB — enough for 4+ h audio)
MAX_UPLOAD_MB=2048

# Apply text cleaning by default (filler removal, dedup, paragraph merging)
CLEAN_OUTPUT_DEFAULT=true

# Drop Whisper segments with avg_logprob below this value (0.0 = keep all)
MIN_SEGMENT_CONFIDENCE=0.0

# Job results are kept for this many seconds, then evicted
JOB_TTL_SECONDS=3600

# Maximum simultaneous transcription jobs
MAX_CONCURRENT_JOBS=2

# Requests to /transcribe per minute per IP
RATE_LIMIT_PER_MINUTE=10

# Optional: cache directory for downloaded Whisper model weights
# WHISPER_CACHE=/path/to/model/cache

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
WORKERS=1
